# ========================
# SERVER
# ========================
PORT=3000
NODE_ENV=development

# ========================
# DATABASE
# ========================
# Get your MongoDB Atlas connection string from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/loom?retryWrites=true&w=majority

# ========================
# CLERK AUTH
# ========================
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ========================
# JWT (admin panel)
# ========================
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
ADMIN_JWT_EXPIRES_IN=8h
# Generate with: node -e "const b=require('bcryptjs');b.hash('your_password',12).then(console.log)"
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# ========================
# CLIENT / CORS
# ========================
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
